config {
  type: "view",
  schema: "customer_orders_silver",
  description: "Silver layer: cleaned and standardized customer records",
  assertions: {
    uniqueKey: ["customer_id"],
    nonNull: ["customer_id"]
  }
}

select
  customer_id,
  trim(full_name) as full_name,
  lower(email) as email,
  created_at
from ${ref("customers")}
where customer_id is not null
